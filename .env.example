# Indigo Protocol Indexer
INDEXER_URL=https://analytics.indigoprotocol.io/api

# x402 Payment Configuration (optional - enables pay-per-use)
# Set one or both addresses to enable x402 payments
# X402_EVM_ADDRESS=0xYourBaseWalletAddress
# X402_SOLANA_ADDRESS=YourSolanaWalletAddress

# Set to 'true' for testnet mode (Base Sepolia / Solana Devnet)
# X402_TESTNET=false

# Pricing Tiers (USD per call):
# - Read tools (get_assets, get_cdps_by_owner, etc.): $0.005
# - Analysis tools (analyze_cdp_health, get_tvl, get_apr_rewards): $0.02
# - Write tools (open_cdp, deposit_cdp, leverage_cdp, etc.): $0.10
