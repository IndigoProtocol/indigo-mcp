INDEXER_URL=https://analytics.indigoprotocol.io/api

# ── x402 payment gating (optional — omit to run without payment requirements) ──
# EVM wallet address to receive USDC on Base (required to enable payments)
X402_EVM_ADDRESS=

# Cardano address to receive iUSD/USDM on Cardano (optional)
X402_CARDANO_ADDRESS=

# Set to "true" to use testnets (Base Sepolia, Cardano preprod)
X402_TESTNET=false

# Override default facilitator URL (defaults to https://x402.org/facilitator)
X402_FACILITATOR_URL=
